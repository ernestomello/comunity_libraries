# ==============================================
# CONFIGURACIÓN DOCKER - COMMUNITY LIBRARIES
# ==============================================

# IMPORTANTE: Copia este archivo como .env y configura tus valores reales
# docker cp .env.docker.example .env

# ==============================================
# CONFIGURACIÓN DJANGO
# ==============================================
DEBUG=False
SECRET_KEY=django-super-secret-key-change-this-in-production-please

# ==============================================
# CONFIGURACIÓN DE BASE DE DATOS MARIADB
# ==============================================
DATABASE_NAME=community_libraries
DATABASE_USER=django_user
DATABASE_PASSWORD=secure_django_password_here
DATABASE_ROOT_PASSWORD=very_secure_root_password_here

# ==============================================
# CONFIGURACIÓN DE HOSTS Y URLS
# ==============================================
ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://nginx
CSRF_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://nginx
CORS_ORIGINS_WHITELIST=http://localhost,http://127.0.0.1,http://nginx

# ==============================================
# CONFIGURACIÓN SSL/HTTPS (PRODUCCIÓN)
# ==============================================
# Tu dominio principal (OBLIGATORIO para SSL)
DOMAIN_NAME=tu-dominio.com
# Email para notificaciones de Let's Encrypt
LETSENCRYPT_EMAIL=admin@tu-dominio.com
# Configuraciones HTTPS para Django
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ==============================================
# CONFIGURACIÓN DE EMAIL (GMAIL)
# ==============================================
# Para usar Gmail necesitas habilitar verificación en 2 pasos
# y generar una "contraseña de aplicación"
EMAIL_HOST_USER=tu-biblioteca@gmail.com
EMAIL_HOST_PASSWORD=tu-contraseña-de-aplicacion-gmail
DEFAULT_FROM_EMAIL=Sistema de Bibliotecas <tu-biblioteca@gmail.com>

# ==============================================
# CONFIGURACIÓN ALTCHA (CAPTCHA)
# ==============================================
ALTCHA_HMAC_KEY=altcha-hmac-key-change-this-for-production-security

# ==============================================
# CONFIGURACIÓN SUPERUSUARIO
# ==============================================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@bibliotecas.com
DJANGO_SUPERUSER_PASSWORD=admin_secure_password_123

# ==============================================
# CONFIGURACIÓN PARA PRODUCCIÓN
# ==============================================
# Descomenta y configura estas variables para producción

# Para usar con dominio real:
# ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com
# CSRF_TRUSTED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
# CSRF_ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# Para SSL/HTTPS:
# CSRF_COOKIE_SECURE=True
# SESSION_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=True