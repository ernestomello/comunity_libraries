# Configuración de Django
SECRET_KEY=tu-clave-secreta-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Configuración de base de datos
NAME=nombre_base_datos
MYSQL_USER=usuario
MYSQL_PASSWORD=password
HOST=localhost
PORT=3306

# Configuración de Altcha
# Cambia esta clave por una unique y segura en producción
ALTCHA_HMAC_KEY=tu-clave-hmac-altcha-securizada-aqui

# URLs
STATIC_URL=static/
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
CSRF_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
CORS_ORIGINS_WHITELIST=http://localhost,http://127.0.0.1