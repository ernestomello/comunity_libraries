# Configuración de Django
SECRET_KEY=tu-clave-secreta-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Configuración de base de datos
NAME=nombre_base_datos
MYSQL_USER=usuario
MYSQL_PASSWORD=password
HOST=localhost
PORT=3306

# Configuración de Altcha
# Cambia esta clave por una unique y segura en producción
ALTCHA_HMAC_KEY=tu-clave-hmac-altcha-securizada-aqui

# URLs
STATIC_URL=static/
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
CSRF_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Configuración de Email - Gmail
# IMPORTANTE: Usa App Password, no tu contraseña regular de Gmail!
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=abcd efgh ijkl mnop
DEFAULT_FROM_EMAIL=Sistema de Bibliotecas <tu-email@gmail.com>

# Cómo obtener App Password:
# 1. Ve a la configuración de tu cuenta de Google: https://myaccount.google.com/
# 2. Seguridad → Verificación en 2 pasos (actívala primero)
# 3. Contraseñas de aplicaciones → Selecciona "Aplicación personalizada" → Nómbrala "Django Bibliotecas"
# 4. Copia la contraseña de 16 caracteres y pégala arriba (con espacios tal como aparece)
CORS_ORIGINS_WHITELIST=http://localhost,http://127.0.0.1