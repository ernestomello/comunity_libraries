# Configuración para producción en PythonAnywhere
# Copia este archivo a .env en el servidor y modifica los valores

# Configuración de Django
DEBUG=False
SECRET_KEY=tu_nueva_secret_key_para_produccion_muy_larga_y_segura_12345

# Configuración de base de datos MySQL
DATABASE_NAME=tu_usuario_mysql$nombrebasededatos
DATABASE_USER=tu_usuario_mysql
DATABASE_PASSWORD=tu_password_mysql
DATABASE_HOST=tu_usuario_mysql.mysql.pythonanywhere-services.com
DATABASE_PORT=3306

# Configuración de Altcha
ALTCHA_HMAC_KEY=tu_clave_secreta_para_altcha_diferente_a_desarrollo

# Configuración de archivos estáticos
STATIC_URL=/static/
STATIC_ROOT=/home/tu_usuario_pythonanywhere/comunity_libraries/static_collected/

# Hosts permitidos (reemplaza con tu dominio de PythonAnywhere)
ALLOWED_HOSTS=tu_usuario_pythonanywhere.pythonanywhere.com

# Configuración adicional para producción
USE_TZ=True
LANGUAGE_CODE=es